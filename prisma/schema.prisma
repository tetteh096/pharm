// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  PHARMACIST
  STAFF
}

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  password          String    // bcrypt hash
  role              Role      @default(STAFF)
  department        String?   // e.g. "Dispensary", "Procurement"
  phone             String?
  image             String?   // profile picture (data URL or external URL)
  active            Boolean   @default(true)
  resetToken        String?   // password reset token
  resetTokenExpiry  DateTime? // token expiry
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ─── Pharmacy ────────────────────────────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String?   @unique
  products  Product[]
}

model Branch {
  id         String   @id @default(cuid())
  name       String   @unique
  slug       String?  @unique
  location   String?  // street / area
  phone      String?
  tel        String?  // dialable form, e.g. "0554612072"
  gps        String?  // GhanaPostGPS code
  hours      String?  // e.g. "Mon–Sat 8am–8pm"
  notes      String?
  maps       String?  // Google Maps directions URL
  mapEmbed   String?  // Google Maps embed URL
  accent     String?  @default("#13ec8a") // brand accent colour for this branch
  comingSoon Boolean  @default(false)
  sortOrder  Int      @default(0)
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Product {
  id              String   @id @default(cuid())
  name            String
  description     String?
  sku             String?  @unique
  costPrice       Float    @default(0)
  price           Float    // regular selling price (GH₵). When discountPercent > 0, customers pay price * (1 - discountPercent/100).
  discountPercent Int      @default(0) // 0–99
  stock           Int      @default(0)
  lowStockAt      Int      @default(10)
  status          String   @default("Out of Stock")
  active          Boolean  @default(true)
  featured        Boolean  @default(false)
  image           String?  // primary thumbnail (data URL or external URL)
  images          String[] @default([])
  tags            String[] @default([])
  branch          String?
  expiryDate      DateTime? // optional product expiry (pharmacy)
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── Blog ────────────────────────────────────────────────────────────────────

model BlogCategory {
  id    String     @id @default(cuid())
  name  String     @unique
  posts BlogPost[]
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverImage  String?
  authorName  String   @default("Admin")
  status      String   @default("Draft")
  views       Int      @default(0)
  tags        String[]

  categoryId  String?
  category    BlogCategory? @relation(fields: [categoryId], references: [id])

  comments    BlogComment[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BlogComment {
  id        String   @id @default(cuid())
  postId    String
  post      BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  message   String
  approved  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([postId])
}

// ─── Orders & patients ───────────────────────────────────────────────────────

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Customer {
  id           String    @id @default(cuid())
  name         String
  email        String?
  phone        String?

  // Demographics
  dateOfBirth  DateTime?
  gender       String?

  // Contact
  address      String?
  emergencyContactName  String?
  emergencyContactPhone String?

  // Medical
  allergies    String[]
  medicalNotes String?

  // Classification
  clientType   String    @default("Regular")
  condition    String?
  source       String?   // "Online order", "Walk-in", "Manual", "Phone"
  notes        String?

  // Refill scheduling (existing fields)
  lastRefillAt DateTime?
  nextRefillAt DateTime?

  status        String    @default("Active")
  createdById   String?
  createdByName String?

  orders        Order[]
  chronicRecord ChronicPatient?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ChronicPatient {
  id                 String    @id @default(cuid())
  customerId         String    @unique
  customer           Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  assignedToId       String?
  assignedToName     String?

  condition          String
  currentMedications String[]
  dosageSchedule     String?
  status             String    @default("Active") // Active, Inactive, Lost

  lastContactAt      DateTime?
  nextCheckInAt      DateTime?

  notes              String?

  checkIns           ChronicCheckIn[]

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([assignedToId])
  @@index([nextCheckInAt])
  @@index([status])
}

model ChronicCheckIn {
  id                 String         @id @default(cuid())
  chronicPatientId   String
  chronicPatient     ChronicPatient @relation(fields: [chronicPatientId], references: [id], onDelete: Cascade)

  contactedAt        DateTime       @default(now())
  contactedById      String?
  contactedByName    String?

  method             String         // PHONE, IN_PERSON, SMS, EMAIL, WHATSAPP
  outcome            String         // REACHED, NO_ANSWER, NEEDS_REFILL, REFILLED, RESCHEDULED, OTHER
  needsRefill        Boolean        @default(false)
  notes              String?

  /** When set, becomes the chronic record's next nextCheckInAt. */
  nextCheckInAt      DateTime?

  createdAt          DateTime       @default(now())

  @@index([chronicPatientId])
  @@index([contactedAt])
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status          OrderStatus @default(PENDING)
  paymentMethod   String?
  total           Float
  // Fulfillment & delivery
  fulfillmentType String?     // "PICKUP" or "DELIVERY"
  branchName      String?
  deliveryAddress String?
  deliveryNotes   String?
  deliveryLat     Float?
  deliveryLng     Float?
  items           OrderItem[]
  statusLogs      OrderStatusLog[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderStatusLog {
  id            String      @id @default(cuid())
  orderId       String
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fromStatus    OrderStatus?
  toStatus      OrderStatus
  changedById   String?
  changedByName String?
  changedByEmail String?
  note          String?
  createdAt     DateTime    @default(now())

  @@index([orderId])
  @@index([createdAt])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?
  productName String
  quantity    Int     @default(1)
  unitPrice   Float
  unitCost    Float?  // snapshot of cost price at time of sale (for accounting)
}

// ─── Consultation requests (from website "Book a Free Consultation" form) ────

model ConsultationRequest {
  id                 String   @id @default(cuid())
  idempotencyKey     String?  @unique
  fullName           String
  email              String
  phone              String
  medicationInterest String?
  message            String
  status             String   @default("New")  // New | In Progress | Done | Dismissed
  handledById        String?
  handledByName      String?
  handledAt          DateTime?
  notes              String?  // internal staff notes
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ─── Contact form messages (from website Contact page) ─────────────────────

model ContactMessage {
  id            String   @id @default(cuid())
  idempotencyKey String? @unique
  fullName      String
  email         String
  phone         String
  branchId      String
  branchName    String
  subject       String
  message       String
  status        String   @default("New")  // New | In Progress | Done | Dismissed
  handledById   String?
  handledByName String?
  handledAt     DateTime?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([branchId])
}

// ─── Public website team (Team page — not dashboard staff accounts) ───────────

model TeamProfile {
  id           String   @id @default(cuid())
  name         String
  role         String
  image        String?  // data URL or external URL
  facebookUrl  String?
  linkedinUrl  String?
  instagramUrl String?
  sortOrder    Int      @default(0)
  published    Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([published, sortOrder])
}

// ─── Public website settings (singleton — admin editable) ─────────────────────

model SiteSettings {
  id String @id @default("site")

  contactEmail String?

  facebookUrl  String?
  linkedinUrl  String?
  instagramUrl String?
  twitterUrl   String?
  tiktokUrl    String?

  whatsappMadina   String?
  whatsappOdorkor  String?
  whatsappSakumono String?
  whatsappSanteo   String?

  updatedAt DateTime @updatedAt
}
